{
  "name": "decision-lab",
  "version": "0.2.0",
  "description": "A schema-first personal decision operating system for investment, finance, and management judgment.",
  "type": "module",
  "private": true,
  "bin": {
    "decision-lab": "./bin/decision-lab.js"
  },
  "scripts": {
    "check": "node --check bin/decision-lab.js && node --check src/decision-core.js && node --check src/templates.js && node --check test/decision-core.test.js",
    "test": "node --test",
    "example:investment": "node bin/decision-lab.js render examples/investment/nvidia_add_position.json",
    "example:business": "node bin/decision-lab.js render examples/business/enterprise_pricing_change.json",
    "example:audit": "node bin/decision-lab.js audit examples/business/enterprise_pricing_change.json",
    "example:prompts": "node bin/decision-lab.js prompt all examples/business/enterprise_pricing_change.json --out-dir outputs/prompts"
  },
  "keywords": [
    "decision",
    "investment",
    "management",
    "schema",
    "memo"
  ],
  "license": "MIT"
}
