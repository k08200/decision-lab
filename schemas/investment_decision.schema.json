{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/decision-lab/investment_decision.schema.json",
  "title": "Investment Decision",
  "allOf": [
    { "$ref": "./general_decision.schema.json" },
    {
      "type": "object",
      "required": ["asset", "valuation", "catalysts", "risk_controls"],
      "properties": {
        "decision_type": { "const": "investment" },
        "asset": {
          "type": "object",
          "required": ["name", "ticker", "asset_class", "time_horizon", "proposed_action"],
          "properties": {
            "name": { "type": "string" },
            "ticker": { "type": "string" },
            "asset_class": { "type": "string" },
            "market": { "type": "string" },
            "time_horizon": { "type": "string" },
            "proposed_action": { "type": "string" }
          }
        },
        "valuation": {
          "type": "object",
          "required": ["base_case", "bull_case", "bear_case"],
          "properties": {
            "current_price": { "type": ["number", "null"] },
            "base_case": { "type": "string" },
            "bull_case": { "type": "string" },
            "bear_case": { "type": "string" },
            "margin_of_safety": { "type": "string" }
          }
        },
        "catalysts": { "type": "array", "items": { "type": "string" } },
        "risk_controls": { "type": "array", "items": { "type": "string" } }
      }
    }
  ]
}
